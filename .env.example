# --- CELESTIA JOURNEY API KEYS ---

# OpenAI: Get yours at https://platform.openai.com/
# Used for the Architect Agent (Itinerary Generation)
OPENAI_API_KEY="add your open ai api key"

# Serper: Get a free key at https://serper.dev/
# Used for the Researcher Agent (Real-time Google Search)
SERPER_API_KEY="add real key"

# Upstash Redis: Get a free instance at https://upstash.com/
# Used for caching itineraries to save costs and improve speed
UPSTASH_REDIS_REST_URL="add url"
UPSTASH_REDIS_REST_TOKEN="add secret token"

# --- CONFIGURATION ---

# Leave blank for local development, or set your production domain
NEXT_PUBLIC_BACKEND_URL=
